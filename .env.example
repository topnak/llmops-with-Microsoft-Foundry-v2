# Microsoft Foundry LLMOps Demo — Environment Variables
# Copy this file to .env and fill in your values.

# Azure Service Principal credentials
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# Azure region
AZURE_LOCATION=australiaeast

# Microsoft Foundry project endpoint (existing)
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://llmops-foundry.services.ai.azure.com/api/projects/llm-ops-foundry-demo

# Optional resource IDs (used by some workflows)
AZURE_EXISTING_AIPROJECT_RESOURCE_ID=
AZURE_EXISTING_RESOURCE_ID=

# Azure Developer CLI
AZURE_ENV_NAME=llmops-demo
AZD_ALLOW_NON_EMPTY_FOLDER=true

# Primary model deployment name
PRIMARY_MODEL=gpt-4.1-mini

# Comparison models (comma-separated deployment names)
COMPARISON_MODELS=gpt-4.1-mini,gpt-4.1

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
